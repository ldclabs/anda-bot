{
	"manifest_version": 3,
	"name": "Anda Bot",
	"version": "0.1.0",
	"description": "Chat with Anda Bot from Chrome and let the agent operate the current webpage.",
	"minimum_chrome_version": "116",
	"permissions": ["activeTab", "scripting", "sidePanel", "storage", "tabs", "tts"],
	"host_permissions": ["http://*/", "https://*/"],
	"optional_host_permissions": ["file:///"],
	"background": {
		"service_worker": "service_worker.js",
		"type": "module"
	},
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http: https: ws: wss:;"
	},
	"action": {
		"default_title": "Open Anda Bot"
	},
	"side_panel": {
		"default_path": "index.html"
	},
	"icons": {
		"16": "icons/logo16hdr.png",
		"32": "icons/logo32hdr.png",
		"48": "icons/logo48hdr.png",
		"128": "icons/logo128hdr.png"
	}
}
