# anda_bot local chat configuration
#
# This file is created automatically on first launch.
# Edit the values below, save the file, then restart `anda` or press Ctrl+R in the TUI.
#
# Required keys for Chat:
#   MODEL_FAMILY   Provider family, such as anthropic, openai, gemini, or deepseek
#   MODEL_NAME     Exact model identifier exposed by your provider
#   MODEL_API_KEY  Provider API key
#   MODEL_API_BASE Provider API base URL, including version suffix when required
#
# Optional keys:
#   GATEWAY_ADDR   Local daemon bind address
#   SANDBOX        true enables sandboxed skill execution
#   HTTPS_PROXY    Outbound HTTPS proxy URL
#
# Example providers:
#   Anthropic
#     MODEL_FAMILY=anthropic
#     MODEL_NAME=claude-sonnet-4-5
#     MODEL_API_BASE=https://api.anthropic.com/v1
#
#   OpenAI-compatible
#     MODEL_FAMILY=openai
#     MODEL_NAME=gpt-4.1-mini
#     MODEL_API_BASE=https://api.openai.com/v1

GATEWAY_ADDR=127.0.0.1:8042
SANDBOX=false

MODEL_FAMILY=''
MODEL_NAME=''
MODEL_API_KEY=''
MODEL_API_BASE=''

# Optional: for example http://127.0.0.1:7890
# HTTPS_PROXY=''